# ── JWT — gere com: openssl rand -hex 32 ─────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://crm.amorefood.com.br
