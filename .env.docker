FRONTEND_IMAGE=ghcr.io/pullseiabr-lgtm/pullse-sistema-restaurantes/frontend:latest


# ── Domínio ──────────────────────────────────────────────────────────────
DOMAIN=crm.amorefood.com.br

# ── Banco de dados ────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TrocaEssaSenha2026!
