{
  "name": "amore-restaurante",
  "version": "0.1.0",
  "private": true,
  "description": "Replicação do sistema Foozi (gestão de compras de restaurantes) — React + TypeScript + NestJS + Supabase",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml,yaml}\"",
    "db:generate": "pnpm --filter @amore/backend prisma:generate",
    "db:migrate": "pnpm --filter @amore/backend prisma:migrate",
    "db:seed": "pnpm --filter @amore/backend prisma:seed",
    "db:reset": "pnpm --filter @amore/backend prisma:reset",
    "db:studio": "pnpm --filter @amore/backend prisma:studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
