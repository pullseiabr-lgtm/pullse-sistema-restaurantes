{
  "name": "amore-restaurante",
  "version": "0.1.0",
  "private": true,
  "description": "Replicação do sistema Foozi (gestão de compras de restaurantes) — React + TypeScript + NestJS + Supabase",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "build": "npm --workspace @amore/frontend run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml,yaml}\"",
    "db:generate": "npm --workspace @amore/backend run prisma:generate",
    "db:migrate": "npm --workspace @amore/backend run prisma:migrate",
    "db:seed": "npm --workspace @amore/backend run prisma:seed",
    "db:reset": "npm --workspace @amore/backend run prisma:reset",
    "db:studio": "npm --workspace @amore/backend run prisma:studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
