# =====================================================================
# Variáveis de ambiente — copie para .env e preencha valores reais
# NUNCA commite o arquivo .env. Use cofre de segredos em produção.
# =====================================================================

# ---------- Supabase / Postgres ----------
# Connection string para o Prisma. Obtenha em Supabase Dashboard → Project Settings → Database → Connection String.
# Use a "Connection pooling" URL (porta 6543) para serverless e a direta (5432) só em migrations.
DATABASE_URL="postgresql://postgres:SENHA@db.SEUPROJETO.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:SENHA@db.SEUPROJETO.supabase.co:5432/postgres"

SUPABASE_URL="https://SEUPROJETO.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---------- JWT ----------
# Gere com: openssl rand -hex 32
JWT_SECRET=""
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_EXPIRES_IN="30d"

# ---------- Backend ----------
NODE_ENV="development"
PORT="3001"
CORS_ORIGINS="http://localhost:5173"
API_PREFIX="api/v1"

# ---------- Superadmin (usado pelo seed) ----------
SUPERADMIN_EMAIL="admin@empresa.com.br"
# Mínimo 12 chars, com maiúscula, número e símbolo. Trocar no primeiro login.
SUPERADMIN_PASSWORD="Trocar@Mudar2026!"
SUPERADMIN_NAME="Super Admin"

# ---------- Frontend (Vite) ----------
VITE_API_URL="http://localhost:3001/api/v1"
VITE_SUPABASE_URL="https://SEUPROJETO.supabase.co"
VITE_SUPABASE_ANON_KEY=""
